# rename this to .env
# NOTE: after Phase 2 of the consolidation plan this file goes away entirely.
# All config lives in websocket-server/.env.

# Required when pointing the Next.js frontend at a remote backend (e.g. production)
# Omit or leave blank for local dev (defaults to http://localhost:8081)
NEXT_PUBLIC_REMOTE_BACKEND=""

# Set to "true" to enable verbose transcript debug logging in the browser
NEXT_PUBLIC_DEBUG_TRANSCRIPT=""