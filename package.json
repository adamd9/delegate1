{
  "name": "delegate1",
  "version": "1.0.0",
  "description": "Single-threaded multi-channel AI assistant",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/twiml.xml dist/ && mkdir -p dist/config && cp -R src/config/* dist/config/ || true",
    "start": "node dist/server.js",
    "dev": "bash scripts/kill-ports.sh && nodemon --watch 'src/**/*' --watch '.env' --ext 'ts,js,xml,env' --exec 'ts-node' src/server.ts",
    "kill-ports": "bash scripts/kill-ports.sh",
    "test:e2e": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npx -y @playwright/test@1.55.0 test",
    "test:e2e:headed": "npx -y @playwright/test@1.55.0 test --headed",
    "test:voice": "ts-node src/voice/voicePipeline.test.ts",
    "test:unit": "ts-node tests/unit/memory-deduplicator.test.ts",
    "clean": "rm -rf node_modules dist",
    "script:token": "node scripts/twilio/generate-token.js",
    "script:list-apps": "node scripts/twilio/list-twiml-apps.js",
    "script:inspect-app": "node scripts/twilio/inspect-twiml-app.js",
    "script:create-app": "node scripts/twilio/create-twiml-app.js",
    "script:update-app": "node scripts/twilio/update-twiml-app.js",
    "script:validate-token": "node scripts/debug/validate-token.js",
    "script:test-api-key": "node scripts/debug/test-api-key.js",
    "script:test-direct-api": "node scripts/debug/test-direct-api.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@openai/agents": "^0.0.5",
    "@types/imap-simple": "^4.2.10",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.1",
    "@types/ws": "^8.5.12",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "httpdispatcher": "^2.2.0",
    "https-proxy-agent": "^5.0.1",
    "imap-simple": "^5.1.0",
    "mailparser": "^3.7.4",
    "marked": "^16.1.2",
    "mem0ai": "^2.1.37",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "openai": "^5.12.2",
    "ts-node": "^10.9.2",
    "twilio": "^5.8.0",
    "typescript": "^5.5.4",
    "undici": "^7.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "nodemon": "^2.0.22"
  },
  "keywords": [
    "ai",
    "assistant",
    "realtime",
    "voice",
    "twilio",
    "openai"
  ],
  "author": "",
  "license": "ISC"
}
