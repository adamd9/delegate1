{
  "name": "delegate1",
  "version": "1.0.0",
  "description": "Single-threaded, multi-channel AI assistant with voice, text, and phone capabilities",
  "private": true,
  "workspaces": [
    "webapp",
    "websocket-server"
  ],
  "scripts": {
    "kill-ports": "bash scripts/kill-ports.sh",
    "predev": "npm run kill-ports",
    "dev": "npm run kill-ports && npm run backend:dev",
    "start": "npm run backend:start",
    "build": "npm run frontend:build && npm run backend:build",
    "backend:dev": "cd websocket-server && npm run dev",
    "backend:start": "cd websocket-server && npm start",
    "backend:build": "cd websocket-server && npm run build",
    "frontend:build": "cd webapp && npm run build",
    "install:all": "npm install",
    "test:e2e": "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npx -y @playwright/test@1.55.0 test",
    "test:e2e:headed": "npx -y @playwright/test@1.55.0 test --headed",
    "clean": "rm -rf node_modules websocket-server/node_modules webapp/node_modules websocket-server/dist",
    "script:token": "node scripts/twilio/generate-token.js",
    "script:list-apps": "node scripts/twilio/list-twiml-apps.js",
    "script:inspect-app": "node scripts/twilio/inspect-twiml-app.js",
    "script:create-app": "node scripts/twilio/create-twiml-app.js",
    "script:update-app": "node scripts/twilio/update-twiml-app.js",
    "script:validate-token": "node scripts/debug/validate-token.js",
    "script:test-api-key": "node scripts/debug/test-api-key.js",
    "script:test-direct-api": "node scripts/debug/test-direct-api.js",
    "ask": "node scripts/ask.js",
    "ask:simple": "npm run ask -- \"What is 2 + 2?\"",
    "ask:complex": "npm run ask -- \"Please escalate this to the supervisor and tell me our company policy on data privacy.\""
  },
  "devDependencies": {
    "ws": "^8.18.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "realtime",
    "voice",
    "twilio",
    "openai",
    "multi-channel"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.1",
    "http-proxy-agent": "^7.0.2",
    "openai": "^5.12.2",
    "twilio": "^5.8.0"
  }
}
